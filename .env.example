# YouTube Data API v3
YOUTUBE_API_KEY=

# OpenAI-compatible (optional; used when provider=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter (optional; used when provider=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# xAI Grok — not supported by this repo’s HTTP client; placeholder only
GROK_API_KEY=
