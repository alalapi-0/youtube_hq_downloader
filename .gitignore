# Generated pipeline intermediates / exports (fixtures + examples committed separately)
/data/raw/*.jsonl
/data/enriched/*.jsonl
/data/filtered/*.jsonl
/data/rejected/*.jsonl
/data/url_analysis/*.local.jsonl
/data/manual_reviews/*.local.jsonl

/output/csv/*.csv
/output/jsonl/*.jsonl
/output/markdown/*.md
/output/search_plan.yaml
/output/_console*
/output/tasks/*
!/output/tasks/.gitkeep

# Console / runtime logs (keep directory via .gitkeep)
logs/*.log
logs/
!logs/
logs/*
!logs/.gitkeep
