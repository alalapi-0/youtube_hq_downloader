cache/*.json

# Generated pipeline intermediates / exports (fixtures + examples committed separately)
/data/raw/*.jsonl
/data/enriched/*.jsonl
/data/filtered/*.jsonl
/data/rejected/*.jsonl

/output/csv/*.csv
/output/jsonl/*.jsonl
/output/markdown/*.md
/output/search_plan.yaml
/output/_console*

# Console / runtime logs (keep directory via .gitkeep)
logs/*.log
!logs/.gitkeep
